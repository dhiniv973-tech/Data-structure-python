class Solution:
    def sort012(self, arr):
        c0 = arr.count(0)
        c1 = arr.count(1)
        c2 = arr.count(2)
        
        i = 0
        
        for _ in range(c0):
            arr[i] = 0
            i += 1
            
        for _ in range(c1):
            arr[i] = 1
            i += 1
            
        for _ in range(c2):
            arr[i] = 2
            i += 1
